<?xml version="1.0" encoding="utf-8"?>
<level xmlns="*" xmlns:mx="http://www.adobe.com/2006/mxml" width="100%" height="100%" creationComplete="initLvl()">
	<mx:Script>
		<![CDATA[

			import AssetManager;
			
			public function initLvl():void
			{	
				soundManager.stopBGM();
				soundManager.currentMusic = "world03";
				
				(this.parent as levelManager).currentLevel = this;

				super.nextLvl = "m2";
				
				//(this.parent as levelManager).currentLevel = this;

				super.setBG(AssetManager.bgWorld3_1);

				// this png determines collision based on transparency.
				super.setGround(AssetManager.levelm1_collision); 
				super.setEntrance(0,460);
				super.setExit(0,87);
				
				// addGraph also takes care of activation orb
				super.addGraph(1,0,60,139,15,260,260,0,300,480,0,0,0,3,20);
				super.addGraph(0,1,350,69,550,225,450,190,0,480,0,0,0,3,20);
				
				//this.spikeObstacleEditor.addSpike(80,290,true,true,true,100,520,50);
				
				var newSwitch:switchObject = new switchObject();
				newSwitch.init((this.parent.parent as game),750,90);
				newSwitch.addObstacle((this.parent.parent as game),220,0,true,true,20,140);
				this.addChild(newSwitch);
				
			}
		]]>
	</mx:Script>
</level>
