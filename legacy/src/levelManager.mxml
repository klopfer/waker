<?xml version="1.0" encoding="utf-8"?>
<mx:Canvas xmlns:mx="http://www.adobe.com/2006/mxml" width="100%" height="100%" horizontalScrollPolicy="off" verticalScrollPolicy="off" xmlns:local="*">
	<mx:Script>
		<![CDATA[
		
			import levels.*;
			
			public var currentLevel:level;
			public var currLvl:String = new String();
			
			/*  these appear to be unused
			public var currWorld:int = 0;
			public var currLevel:int = 0;
			*/
			
			public function loadLvl(levelID:String):void
			{
				(this.parent as game).player.visible=false;				
				
				if (this.getChildren().length>0)
					this.removeAllChildren();
				
				//the levels need time to load, so i am setting back the hack value to 0
				(this.parent as game).childMovements.hack=0;
				
				switch (levelID)
				{
					case "introCutScene":
						currentLevel = new levels.cutsceneIntro();
						break;
					case "d0":
						currentLevel = new levels.displacement0();
						break;
					case "d1":
						currentLevel = new levels.displacement1();
						break;
					case "d2":
						currentLevel = new levels.displacement2();
						break;
					case "d3":
						currentLevel = new levels.displacement3();
						break;
					case "cutsceneDisplacement":
						currentLevel = new levels.cutsceneDisplacement();
						break;
					case "v0":
						currentLevel = new levels.velocity0();
						break;
					case "v1":
						currentLevel = new levels.velocity1();
						break;
					case "v2":
						currentLevel = new levels.velocity2();
						break;
					case "v3":
						currentLevel = new levels.velocity3();
						break;
					case "cutsceneVelocity":
						currentLevel = new levels.cutsceneVelocity();
						break;
					case "m0":
						currentLevel = new levels.mixed0();
						break;
					case "m1":
						currentLevel = new levels.mixed1();
						break;
					case "m2":
						currentLevel = new levels.mixed2();
						break;
					case "m3":
						currentLevel = new levels.mixed3();
						break;
					case "cutsceneMixed":
						currentLevel = new levels.cutsceneMixed();
						break;
					case "99":
						currentLevel = new levels.level_template();
						break;
					case "gameending":
						currentLevel = new levels.gameending();
						break;
					default:
						currentLevel = new levels.cutsceneIntro();		
						break;
				}

				this.currLvl=levelID;
				this.addChild(currentLevel);
			}
		]]>
	</mx:Script>
	
</mx:Canvas>
