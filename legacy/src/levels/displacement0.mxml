<?xml version="1.0" encoding="utf-8"?>
<level xmlns="*" xmlns:mx="http://www.adobe.com/2006/mxml" width="100%" height="100%" creationComplete="initLvl()">
	<mx:Script>
		<![CDATA[

			import AssetManager;
			import Settings;
			
			public function initLvl():void
			{
				
				Settings.isItACutScene=false;
				
				soundManager.stopBGM();
				soundManager.currentMusic = "world01";
				
				(this.parent as levelManager).currentLevel = this;

				super.nextLvl = 'd1';
				
				super.setBG(AssetManager.bgWorld1_t);				
				
				// this png determines collision based on transparency:
				super.setGround(AssetManager.levelTD_collision); 
				
				// select img for the entrance and exit and place on the canvas
				super.setExit(750,174);
				super.setEntrance(0,467);
							
				// (this.parent.parent as game).setPlayerLoc(this.entrance.x,this.entrance.y);

				if(Settings.LEVEL_DIFFICULTY == 3)
				{
					// hard
					this.spikeObstacleEditor.addSpike(540,440,false,true,true,500,400,0);
					//this.spikeObstacleEditor.addSpike(340,410,false,true,true,500,400,0);
					
					// place graphs 
					super.addGraph(0,0,800-110-200,134,550,200,200,70,300,290,0,300,273,0,0);
				}
				else if (Settings.LEVEL_DIFFICULTY == 2)
				{
					// medium
					// place graphs 
					super.addGraph(0,0,800-110-200,134,550,200,200,70,300,290,0,300,273,0,0);
				}
				else 
				{
					// easy
					// place graphs 
					super.addGraph(0,0,800-110-200,134,550,200,200,70,300,290,0,300,273,0,0);
				}
				setHint(AssetManager.level_hintsign,AssetManager.level_displacement0_hint,true,5);
				

			}
		]]>
	</mx:Script>
</level>