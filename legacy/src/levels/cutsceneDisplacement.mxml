<?xml version="1.0" encoding="utf-8"?>
<level xmlns="*" xmlns:mx="http://www.adobe.com/2006/mxml" width="100%" height="100%" creationComplete="initLvl()">
	
	<mx:Script>
		<![CDATA[
			
			import AssetManager;
			
			public function initLvl():void
			{	
				Settings.isItACutScene=true;
				
				
				soundManager.varSnd.release();
				soundManager.stopBGM();
				soundManager.currentMusic = "cutScene01";
				trace (soundManager.currentMusic);
				(this.parent as levelManager).currentLevel = this;

				super.nextLvl = "d0";
				super.setBG(AssetManager.preDisplacementCutScene);
				super.setGround(AssetManager.cutScene_collision); 
				super.setEntrance(0,460);
				super.setExit(700,479);
				super.setHint(null);
				

			}
			
		]]>
	</mx:Script>
	
</level>
