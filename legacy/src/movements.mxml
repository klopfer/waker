<mx:Script>
	<![CDATA[
		import mx.controls.Image;
		import GambitLib.HitTest;
		import mx.core.UIComponent;
		import AssetManager;	
		import Settings;
	
/*
////////////////////CONTROL SCHEME////////////////////////
////////////////////CONTROL SCHEME////////////////////////
////////////////////CONTROL SCHEME////////////////////////
////////////////////CONTROL SCHEME////////////////////////
////////////////////CONTROL SCHEME////////////////////////
Detects player keyboard input during gameplay, and alters the boolean value below control scheme
*/
		public function init():void
		{
		
		}
		
		/****************************
		 * checks for player keyinput during gameplay
		 ***************************/
		public function keyPressed(e:KeyboardEvent):void
		{
			//if the player is in the in-game menu
			if((this.parent as game).gameUI.optionsVisible==true && Settings.inGame == true)
				switch(e.keyCode)
				{
					case Keyboard.ESCAPE:   
						if (this.parent.parent != null)
						{
							game(this.parent).gameUI.showOptions();
						}
						Settings.escPressed=true;
						break;	
					
					case Keyboard.RIGHT:
						//if player is in the options menu
						if((this.parent as game).gameUI.optionsShowing==true)
						{
							//if player's focus is on difficulty settings
							if((this.parent as game).gameUI.state_in_sound_option==1)
							{
								//if the difficulty was easy, it gets changed to medium
								if(Settings.LEVEL_DIFFICULTY==1)
								{
									Settings.LEVEL_DIFFICULTY=2;
									(this.parent as game).gameUI.soundOpt.currentState="mediumSelected";
								}
								//if the difficulty was medium, it gets changed to hard
								else if(Settings.LEVEL_DIFFICULTY==2)
								{
									Settings.LEVEL_DIFFICULTY=3;
									(this.parent as game).gameUI.soundOpt.currentState="hardSelected";
								}
							}
							//if player's focus is on the background music menu
							else if((this.parent as game).gameUI.state_in_sound_option==2)
							{
								//if the background music volume isn't max, increase it
								if(soundManager.bgmVolume<1)
								{
									soundManager.bgmVolume+=0.1;
									soundManager.changeVolume(soundManager.bgmVolume);
								}
							}
							//if the player's focus is on the sound effects
							else if((this.parent as game).gameUI.state_in_sound_option==3)
							{
								//if the volume of the sound effects is not min, decrease it
								if(soundManager.sfxVolume<1)
								{
									soundManager.sfxVolume+=0.1;
									soundManager.changeSFXVolume(soundManager.sfxVolume);
									soundManager.playSelect();
								}
							}
						}
						//if the player is at a confirmation screen
						else if((this.parent as game).gameUI.confirmDialogue.visible==true)
						{
							//set selection to no button
							(this.parent as game).gameUI.yes_or_no=false;
						}
						break;
						
					case Keyboard.LEFT:
						//if the player is in the options menu
						if((this.parent as game).gameUI.optionsShowing==true)
						{
							//if the player is focusing on the difficulty settings
							if((this.parent as game).gameUI.state_in_sound_option==1)
							{
								//if the difficulty is currently hard, change it to medium
								if(Settings.LEVEL_DIFFICULTY==3)
								{
									Settings.LEVEL_DIFFICULTY=2;
									(this.parent as game).gameUI.soundOpt.currentState="mediumSelected";
								}
								//if the difficutly is currently medium, change it to easy
								else if(Settings.LEVEL_DIFFICULTY==2)
								{
									Settings.LEVEL_DIFFICULTY=1;
									(this.parent as game).gameUI.soundOpt.currentState="easySelected";
								}
							}
							//if the player is focused on the background music volume
							else if((this.parent as game).gameUI.state_in_sound_option==2)
							{
								//if the background music volume is not min, decrease it
								if(soundManager.bgmVolume>0)
								{
									soundManager.bgmVolume-=0.1;
									soundManager.changeVolume(soundManager.bgmVolume);
								}
							}
							//if the player is focused on the sound effects volume
							else if((this.parent as game).gameUI.state_in_sound_option==3)
							{
								if(soundManager.sfxVolume>0)
								{
									soundManager.sfxVolume-=0.1;
									soundManager.changeSFXVolume(soundManager.sfxVolume);
									soundManager.playSelect();
								}
							}
						}
						//if the player at a confirmation screen, set the selection to yes
						else if((this.parent as game).gameUI.confirmDialogue.visible==true)
						{
						 	(this.parent as game).gameUI.yes_or_no=true;
						}
						break;
						
					case Keyboard.UP:
						//if the player is in the options menu
						if((this.parent as game).gameUI.optionsShowing==true)
						{
							//if the player is focused on the background music volume, shift the focus to difficulty
							if((this.parent as game).gameUI.state_in_sound_option==2)
								(this.parent as game).gameUI.state_in_sound_option=1;
							//if the player is focused on the sound effects volume, shift the focus to the background music volume
							else if((this.parent as game).gameUI.state_in_sound_option==3)
								(this.parent as game).gameUI.state_in_sound_option=2;
						}
						//otherwise, just take note that the player pushed up
						else
							(this.parent as game).gameUI.stateUp=true;
						break;
						
					case Keyboard.DOWN:
						//if the player is in the options menu
						if((this.parent as game).gameUI.optionsShowing==true)
						{
							//if the player is focused on difficulty, shift the focus to background music volume
							if((this.parent as game).gameUI.state_in_sound_option==1)
								(this.parent as game).gameUI.state_in_sound_option=2;
							//if the player is focused on background music volume, shift the focus to sound effects volume
							else if((this.parent as game).gameUI.state_in_sound_option==2)
								(this.parent as game).gameUI.state_in_sound_option=3;
						}
						//otherwise, just take note that down was pressed
						else
							(this.parent as game).gameUI.stateDown=true;
						break;
					
					case Keyboard.ENTER: 
						//if the player is at a confirmation box
						if((this.parent as game).gameUI.confirmDialogue.visible==true)
						{
							//if the player chooses yes, do what the player requested before the confirmation
							if((this.parent as game).gameUI.yes_or_no == true)
								(this.parent as game).gameUI.quitGame(null);
							//otherwise, get rid of the confirmation
							else
								(this.parent as game).gameUI.hideConfirm(null);
						}
						//if the player is in the options menu, close the menu
						else if((this.parent as game).gameUI.optionsShowing==true)
							(this.parent as game).gameUI.closeSoundOpt(null);
						//if the player is in the instructions menu, close the menu
						else if((this.parent as game).gameUI.instructShowing==true)
							(this.parent as game).gameUI.closeInstructions(null);
						//if player is in the in-game menu
						else
							switch((this.parent as game).gameUI.state_of_gui)
							{
								//if the player is focusing on return, get out of the in-game menu
								case 1:
									(this.parent as game).gameUI.showOptions();
									break;
								//if the player is focusing on instructions, bring up the instructions menu
								case 2:
									(this.parent as game).gameUI.showInstructions(null);
									break;
								//if the player is focusing on options, bring up the options menu
								case 3:
									(this.parent as game).gameUI.showSoundOpt(null);
									break;
								//if the player is focusing on restart, bring up a confirmation box
								case 4:
									(this.parent as game).gameUI.showConfirm(null);
									break;
								//if the player is focusing on quit, bring up a confirmation box
								case 5:
									(this.parent as game).gameUI.showConfirm(null);
									break;
							}			
						break;
				}
			//if the player is actually playing the game
			else
				switch(e.keyCode)
				{
					//if the player pushes right, move the avatar to the right
					case Keyboard.RIGHT:	moveRight=true;
											break;
					//if the player pushes left, move the avatar to the left
					case Keyboard.LEFT:		moveLeft=true;
											break;
					//if the player pushes up or spacebar, make the avatar jump
					case Keyboard.SPACE:	
					case Keyboard.UP:
											//the if statement is to make sure that the key is actually being pressed down
											//	and not just held down from a previous loop
											if(tryToJump==false)
											{
											triedJumping=true;
											}
											break;
					//83 for s
					//if the player pushes s, make the avatar sprint
					case 83:				isWalking=false;
											isRunning=true;
											break;
					//68 for d
					//if the player pushes d, take note that they are trying to pick up an orb
					//the if statement is to make sure that the d key is actually being pressed down and not just held down from
					//	a previous loop
					case 68:				if(triedPicking == false)
											{
											tryPicking=true;
											triedPicking=true;
											}
											break;
					//if the player pushes esc, make the in-game menu pop up
					case Keyboard.ESCAPE:   if (this.parent.parent != null)
											{
											game(this.parent).gameUI.showOptions();
											}
											Settings.escPressed=true;
											break;	
					//cheat code
					//////////////////
					//to use cheat, type changyou on keyboard, then press page up
					/////////////////
					//c button
					case 67:	cheatC=true;
								break;
					//h button
					case 72:	if(cheatC==true)
								cheatH=true;
								else
								clearCheat();
								break;
					//a button
					case 65:	if(cheatH==true)
								cheatA=true;
								else
								clearCheat();
								break;
					//n button
					case 78:	if(cheatA==true)
								cheatN=true;
								else
								clearCheat();
								break;
					//g button
					case 71:	if(cheatN==true)
								cheatG=true;
								else
								clearCheat();
								break;
					//y button
					case 89:	if(cheatG==true)
								cheatY=true;
								else
								clearCheat();
								break;
					//o button
					case 79:	if(cheatY==true)
								cheatO=true;
								else
								clearCheat();
								break;
					//u button
					case 85:	if(cheatO==true)
								{
									cheatU=true;
									if((this.parent as game).cheatImg == null)
									{
										(this.parent as game).cheatImg=new Image();
										(this.parent as game).cheatImg.source = AssetManager.cheatSourceFile;
										(this.parent as game).cheatImg.y = 520;
										(this.parent as game).addChild((this.parent as game).cheatImg);
									}
								}
								else
								clearCheat();
								break;
							
				case Keyboard.PAGE_UP: 	if(cheatC==true && cheatH==true && cheatA==true && cheatN==true && 
											cheatG==true && cheatY==true && cheatO==true && cheatU==true)
										{
										game(this.parent).player.y = 0;
										}
										break;
				//end of cheat
			}
		}
		
		//if the player stops pushing up, down, left, space, d, or s, take note
		public function keyLifted(e:KeyboardEvent):void
		{
			switch(e.keyCode)
			{
				case Keyboard.RIGHT:	moveRight=false;
										break;
				case Keyboard.LEFT:		moveLeft=false;
										break;
				case Keyboard.UP:
				case Keyboard.SPACE:	tryToJump=false;
										break;
				case 68:				tryPicking=false;
										triedPicking=false;
										break;
				case 83:				isWalking=true;
										isRunning=false;
										break;
			}
		}


/*
////////////////////CONTROL SCHEME END////////////////////////
////////////////////CONTROL SCHEME END////////////////////////
////////////////////CONTROL SCHEME END////////////////////////
////////////////////CONTROL SCHEME END////////////////////////
