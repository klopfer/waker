/////////////////////MOVEMENTS END//////////////////////////
/////////////////////MOVEMENTS END//////////////////////////
/////////////////////MOVEMENTS END//////////////////////////
/////////////////////MOVEMENTS END//////////////////////////
/////////////////////MOVEMENTS END//////////////////////////
*/
			
		public function applyPhysics():void
		{	
			movementResponse();
			
			playerMovement();
		}
			
		
		//this function is called somewhere, but doesn't actually do anything
		public function updatePlayerPosition():void
		{
		}
	]]>
