*/		

		//to activate cheat.. type changyou in order
		//then press page up to fly up the sky
		//cheat mode
		private var cheatC:Boolean=false;
		private var cheatH:Boolean=false;
		private var cheatA:Boolean=false;
		private var cheatN:Boolean=false;
		private var cheatG:Boolean=false;
		private var cheatY:Boolean=false;
		private var cheatO:Boolean=false;
		private var cheatU:Boolean=false;
		private function clearCheat():void
		{
			cheatC=false;
			cheatH=false;
			cheatA=false;
			cheatN=false;
			cheatG=false;
			cheatY=false;
			cheatO=false;
			cheatU=false;
		}
		
		//boolean values altered by the control scheme above
		//to better understand the difference between move... and acc..., see playerMovement()
		//moveLeft and moveRight are basically short ways of saying keyboard.LEFT and keyboard.RIGHT
		//true if the avatar should be moving left (i.e., true if the player indicates that they want to move left)
		private var moveLeft:Boolean=false;
		//true if the avatar should be moving right (i.e., true if the player indicates that they want to move right)
		private var moveRight:Boolean=false;
		//true if avatar is trying to move left
		private var accLeft:Boolean=false;
		//true if avatar is trying to move right
		private var accRight:Boolean=false;
		//player velocity and acceleration calculated here to move the player velocity
		public var playerVel:Point = new Point(0,0);
		public var playerAccel:Point = new Point(0,0);
		
		//some triedJumping and tryToJump are 2 different boolean as 1 is required to properly determine the other..
		//for eg. when player press triedJumping for the 1st time.. tryToJump is activated... after that, triedJumping will not be activated until
		//tryToJump is deactivated.. 
		//the similar variables are there so that the game can differentiate between a button being pressed down and a button
		//	being held down from a previous loop
		//turns true when the player presses a key that triggers the avatar's jump
		private var triedJumping:Boolean = false;
		//true if the player tried to jump in a previous game loop (i.e., the player is still holding down the key)
		private var tryToJump:Boolean = false;
		//the avatar is always either walking or sprinting, but never both
		//this value is not just one boolean because later there may be other modes of movement
		//true if the avatar is walking
		private var isWalking:Boolean = true;
		//true if the avatar is sprinting
		private var isRunning:Boolean = false;
		//true if the player tried to pick up an item in a previous game loop (i.e., the player is still holding down the key)
		public var tryPicking:Boolean = false;
		//turns true when the player presses a key that triggers the avatar's pick-up action
		private var triedPicking:Boolean = false;
		//true if the player is currently on a solid surface
		public var onGround:Boolean = false;
		private var hack_for_jump_bug_when_platform_is_exactly_at_the_height_for_player_to_walk_through:Boolean = false;
		private var hack_for_jump_bug_when_platform___y_position:Number = 0;
		private var hack_for_the_moving_spikes:Number=0;
		
		//these are to check if the player have been hit by any spikes/damage item.. and keeptrack of the values needed to show the response
		//the response now is a red circle that becomes bigger and fade out
		//true if the player is it
		public var playerHit:Boolean=false;
		//true if the hit effect is playing
		public var playerHitEffect:Boolean=false;
		//keeps track of how many frames of the red circle have been played
		public var playerHitEffectFramesPlayed:int=0;
		//coordinates of where the edge of the avatar hit the obstacle
		public var locationOfHitEffect_X:Number=0;
		public var locationOfHitEffect_Y:Number=0;
		
		//I don't think that this is used anywhere...
		public var pickTimer:int = 0;
/*
