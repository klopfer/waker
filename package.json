{
  "name": "waker-html5",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "HTML5/TypeScript port of the Flash game Waker (codename Woosh2).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write \"{src,tests,tools}/**/*.{ts,js,html,css,json}\" \"*.{ts,js,html,css,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract:swf": "node tools/extract-swf.mjs",
    "extract:swf:dry": "node tools/extract-swf.mjs --dry-run",
    "extract:cutscenes": "node tools/extract-swf.mjs --cutscenes-only",
    "extract:avatar": "node tools/extract-avatar.mjs"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "pixi-filters": "^6.0.5",
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "@types/howler": "^2.2.11",
    "eslint": "^9.15.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
